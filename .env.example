# CalcFlow Environment Variables
# Copy this file to .env.local and update values as needed

# Application Title
VITE_APP_TITLE=CalcFlow - Calculator by Huncho.Dev

# API Configuration (if needed for future features)
VITE_API_BASE_URL=https://api.huncho.dev

# Analytics (optional)
VITE_ANALYTICS_ENABLED=true

# Feature Flags
VITE_ENABLE_SOUND=true
VITE_ENABLE_ANIMATIONS=true
